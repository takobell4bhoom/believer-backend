{
  "name": "believer-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "migrate": "node src/db/migrate.js",
    "seed": "node scripts/seed.js",
    "check": "node --check src/index.js",
    "test": "NODE_ENV=test node --test test/app.test.js test/email.test.js test/prayer-times.test.js test/server.test.js",
    "test:integration:prepare": "node scripts/prepare-integration-db.js",
    "test:integration": "node scripts/run-integration-tests.js",
    "test:integration:run": "node scripts/run-integration-tests.js --run-only"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.3.0",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "pg": "^8.16.3",
    "zod": "^4.1.11"
  }
}
